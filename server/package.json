{
  "name": "server",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "prebuild": "rimraf dist && npm run format",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json  && (concurrently \"tsc -w\" \"tsc-alias -p tsconfig.json -w\")",
    "clean": "rimraf node_modules dist",
    "dev": "tsc --noEmit -p tsconfig.json && tsx ./src/index.ts",
    "dev:watch": "tsc --noEmit -p tsconfig.json && tsx --watch ./src/index.ts",
    "start": "node ./dist/index.js",
    "format": "prettier --no-error-on-unmatched-pattern --ignore-unknown --config ./.prettierrc --write \"./src/**/*.ts\" \"./src/**/*.vue\" "
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "imports": {
    "#/*": "./dist/*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "concurrently": "^10.0.3",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.9.0",
    "yaml": "^2.9.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
